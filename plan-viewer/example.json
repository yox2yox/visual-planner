{
  "title": "認証システム刷新プラン",
  "description": "セッションベースからJWT認証への移行。複雑なフロー全体を「ログイン」「API 呼び出し」の2ペアに分割して表示することで、各ダイアグラムを読みやすく保つ。",
  "glossary": [
    {
      "id": "backend",
      "type": "feature",
      "name": "バックエンド",
      "description": "サーバーサイドの処理を担当するレイヤー",
      "icon": "🖥️"
    },
    {
      "id": "user-auth",
      "type": "feature",
      "name": "ユーザー認証",
      "description": "ログイン・ログアウト・パスワードリセットを担当するモジュール",
      "icon": "🔐",
      "parentId": "backend"
    },
    {
      "id": "auth-validator",
      "type": "feature",
      "name": "資格情報検証",
      "description": "パスワードハッシュの照合など、クレデンシャルの検証を専任で行うサブモジュール（3階層目の表示例）",
      "icon": "✅",
      "parentId": "user-auth"
    },
    {
      "id": "token-issuer",
      "type": "feature",
      "name": "トークン発行",
      "description": "検証済みユーザーに対して JWT を発行するサブモジュール（3階層目の表示例）",
      "icon": "🎟️",
      "parentId": "user-auth"
    },
    {
      "id": "user-service",
      "type": "feature",
      "name": "ユーザーサービス",
      "description": "ユーザー情報のCRUDを提供するマイクロサービス",
      "parentId": "backend"
    },
    {
      "id": "api-gateway",
      "type": "feature",
      "name": "APIゲートウェイ",
      "description": "外部からのリクエストを受け付け、内部サービスにルーティングする",
      "icon": "🌐",
      "parentId": "backend"
    },
    {
      "id": "token-verifier",
      "type": "feature",
      "name": "トークン検証",
      "description": "受信リクエストに付与された認証トークンを検証する",
      "icon": "🔎",
      "parentId": "api-gateway"
    },
    {
      "id": "frontend",
      "type": "feature",
      "name": "フロントエンド",
      "description": "ブラウザ上で動作するユーザー向けアプリケーション",
      "icon": "💻"
    },
    {
      "id": "login-page",
      "type": "feature",
      "name": "ログインページ",
      "description": "ユーザーが資格情報を入力する画面",
      "icon": "🔑",
      "parentId": "frontend"
    },
    {
      "id": "dashboard",
      "type": "feature",
      "name": "ダッシュボード",
      "description": "ログイン後のトップ画面。各種APIを呼び出して情報を表示する",
      "icon": "📊",
      "parentId": "frontend"
    },
    {
      "id": "http-client",
      "type": "feature",
      "name": "HTTPクライアント",
      "description": "バックエンドへのリクエスト送受信を統括するSDK層",
      "icon": "📡",
      "parentId": "frontend"
    },
    {
      "id": "data-layer",
      "type": "data",
      "name": "データストア",
      "description": "永続化されるデータの管理レイヤー",
      "icon": "💾"
    },
    {
      "id": "session",
      "type": "data",
      "name": "セッション",
      "description": "サーバーサイドで管理するユーザーセッション情報",
      "icon": "🗂️",
      "parentId": "data-layer"
    },
    {
      "id": "jwt-token",
      "type": "data",
      "name": "JWTトークン",
      "description": "クライアントサイドで保持するJSONウェブトークン",
      "icon": "🎫",
      "parentId": "data-layer"
    }
  ],
  "pairs": [
    {
      "title": "ログインフロー",
      "description": "資格情報を検証し、認証トークンを発行してクライアントへ配信するまで。",
      "currentState": {
        "description": "サーバーサイドセッションを使用。Cookie 経由でセッション ID を配布する。",
        "interactions": [
          { "source": "login-page", "target": "api-gateway", "label": "ログイン要求", "data": "Credentials" },
          { "source": "api-gateway", "target": "user-auth", "label": "認証委譲", "data": "Credentials" },
          { "source": "user-auth", "target": "auth-validator", "label": "資格検証", "data": "Credentials" },
          { "source": "user-auth", "target": "user-service", "label": "ユーザー取得", "data": "UserID" },
          { "source": "user-auth", "target": "api-gateway", "label": "セッション発行", "data": "SessionID" },
          { "source": "api-gateway", "target": "http-client", "label": "Cookie設定", "data": "SessionID" }
        ]
      },
      "proposedState": {
        "description": "JWT 発行に変更。認証モジュール内に Validator / Issuer を分離。",
        "interactions": [
          { "source": "login-page", "target": "api-gateway", "label": "ログイン要求", "data": "Credentials" },
          { "source": "api-gateway", "target": "user-auth", "label": "認証委譲", "data": "Credentials" },
          { "source": "user-auth", "target": "auth-validator", "label": "資格検証", "data": "Credentials" },
          { "source": "user-auth", "target": "user-service", "label": "ユーザー検索", "data": "Email" },
          { "source": "user-auth", "target": "token-issuer", "label": "発行要求", "data": "UserID" },
          { "source": "user-auth", "target": "api-gateway", "label": "JWT返却", "data": "AuthToken" },
          { "source": "api-gateway", "target": "http-client", "label": "JWT配信", "data": "AuthToken" }
        ]
      }
    },
    {
      "title": "認証済み API 呼び出し",
      "description": "ログイン後にダッシュボードが API を呼び出すときの認証ヘッダ。",
      "currentState": {
        "description": "ブラウザが自動送信する Cookie でサーバーがセッションを参照する。",
        "interactions": [
          { "source": "dashboard", "target": "api-gateway", "label": "API呼び出し", "data": "Cookie" },
          { "source": "api-gateway", "target": "session", "label": "セッション参照", "data": "SessionID" },
          { "source": "api-gateway", "target": "user-service", "label": "データ取得", "data": "UserID" }
        ]
      },
      "proposedState": {
        "description": "Authorization ヘッダに JWT を載せて送信し、ゲートウェイが署名検証する。",
        "interactions": [
          { "source": "dashboard", "target": "api-gateway", "label": "API呼び出し", "data": "Authorization: Bearer" },
          { "source": "api-gateway", "target": "token-verifier", "label": "署名検証", "data": "AuthToken" },
          { "source": "api-gateway", "target": "user-service", "label": "データ取得", "data": "UserID" }
        ]
      }
    }
  ]
}

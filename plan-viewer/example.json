{
  "title": "認証システム刷新プラン",
  "description": "セッションベースからJWT認証への移行により、スケーラビリティとセキュリティを向上させる。フロントエンド／バックエンド間の相互接続を整理し、認証モジュール内部の責務分割（Validator / Issuer）を可視化する。",
  "glossary": [
    {
      "id": "backend",
      "type": "feature",
      "name": "バックエンド",
      "description": "サーバーサイドの処理を担当するレイヤー",
      "icon": "🖥️"
    },
    {
      "id": "user-auth",
      "type": "feature",
      "name": "ユーザー認証",
      "description": "ログイン・ログアウト・パスワードリセットを担当するモジュール",
      "icon": "🔐",
      "parentId": "backend"
    },
    {
      "id": "auth-validator",
      "type": "feature",
      "name": "資格情報検証",
      "description": "パスワードハッシュの照合など、クレデンシャルの検証を専任で行うサブモジュール（3階層目の表示例）",
      "icon": "✅",
      "parentId": "user-auth"
    },
    {
      "id": "token-issuer",
      "type": "feature",
      "name": "トークン発行",
      "description": "検証済みユーザーに対して JWT を発行するサブモジュール（3階層目の表示例）",
      "icon": "🎟️",
      "parentId": "user-auth"
    },
    {
      "id": "user-service",
      "type": "feature",
      "name": "ユーザーサービス",
      "description": "ユーザー情報のCRUDを提供するマイクロサービス",
      "parentId": "backend"
    },
    {
      "id": "api-gateway",
      "type": "feature",
      "name": "APIゲートウェイ",
      "description": "外部からのリクエストを受け付け、内部サービスにルーティングする",
      "icon": "🌐",
      "parentId": "backend"
    },
    {
      "id": "frontend",
      "type": "feature",
      "name": "フロントエンド",
      "description": "ブラウザ上で動作するユーザー向けアプリケーション",
      "icon": "💻"
    },
    {
      "id": "login-page",
      "type": "feature",
      "name": "ログインページ",
      "description": "ユーザーが資格情報を入力する画面",
      "icon": "🔑",
      "parentId": "frontend"
    },
    {
      "id": "dashboard",
      "type": "feature",
      "name": "ダッシュボード",
      "description": "ログイン後のトップ画面。各種APIを呼び出して情報を表示する",
      "icon": "📊",
      "parentId": "frontend"
    },
    {
      "id": "http-client",
      "type": "feature",
      "name": "HTTPクライアント",
      "description": "バックエンドへのリクエスト送受信を統括するSDK層",
      "icon": "📡",
      "parentId": "frontend"
    },
    {
      "id": "data-layer",
      "type": "data",
      "name": "データストア",
      "description": "永続化されるデータの管理レイヤー",
      "icon": "💾"
    },
    {
      "id": "session",
      "type": "data",
      "name": "セッション",
      "description": "サーバーサイドで管理するユーザーセッション情報",
      "icon": "🗂️",
      "parentId": "data-layer"
    },
    {
      "id": "jwt-token",
      "type": "data",
      "name": "JWTトークン",
      "description": "クライアントサイドで保持するJSONウェブトークン",
      "icon": "🎫",
      "parentId": "data-layer"
    },
    {
      "id": "audit-log",
      "type": "term",
      "name": "監査ログ",
      "description": "セキュリティイベントや認証試行を記録するログストレージ",
      "icon": "📋"
    }
  ],
  "currentState": {
    "description": "現在はサーバーサイドセッションを使用。フロントエンドはCookie経由でセッションIDをやり取りし、バックエンドがセッションストアを参照する。スケールアウト時にセッション共有が課題。",
    "interactions": [
      { "source": "login-page", "target": "api-gateway", "label": "ログイン要求", "data": "Credentials" },
      { "source": "api-gateway", "target": "user-auth", "label": "認証委譲", "data": "Credentials" },
      { "source": "user-auth", "target": "auth-validator", "label": "資格検証", "data": "Credentials" },
      { "source": "user-auth", "target": "user-service", "label": "ユーザー取得", "data": "UserID" },
      { "source": "user-auth", "target": "api-gateway", "label": "セッション発行", "data": "SessionID" },
      { "source": "api-gateway", "target": "http-client", "label": "Cookie設定", "data": "SessionID" },
      { "source": "http-client", "target": "dashboard", "label": "ログイン完了", "data": "SessionID" },
      { "source": "dashboard", "target": "api-gateway", "label": "API呼び出し", "data": "Cookie" }
    ]
  },
  "proposedState": {
    "description": "JWTを導入してステートレス認証を実現。認証モジュール内に Validator と Issuer を分離し、責務を明確化。フロントエンドはJWTをヘッダで送出する。",
    "interactions": [
      { "source": "login-page", "target": "api-gateway", "label": "ログイン要求", "data": "Credentials" },
      { "source": "api-gateway", "target": "user-auth", "label": "認証委譲", "data": "Credentials" },
      { "source": "user-auth", "target": "auth-validator", "label": "資格検証", "data": "Credentials" },
      { "source": "user-auth", "target": "user-service", "label": "ユーザー検索", "data": "Email" },
      { "source": "user-auth", "target": "token-issuer", "label": "発行要求", "data": "UserID" },
      { "source": "user-auth", "target": "api-gateway", "label": "JWT返却", "data": "AuthToken" },
      { "source": "api-gateway", "target": "http-client", "label": "JWT配信", "data": "AuthToken" },
      { "source": "http-client", "target": "dashboard", "label": "ログイン完了", "data": "AuthToken" },
      { "source": "dashboard", "target": "api-gateway", "label": "API呼び出し", "data": "Authorization: Bearer" }
    ]
  }
}
